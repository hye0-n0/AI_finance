        "def largest_firms(df, feature):\n",
        "    \"\"\"\n",
        "    This is a function for listing five most popular firms in cluster\n",
        "    :df: dataframe\n",
        "    :feature: a feature you want to sort by\n",
        "    :return: dataframe with names of largest firms with feature\n",
